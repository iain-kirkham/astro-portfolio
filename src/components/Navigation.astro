---
import { links } from "src/data/utils";

const currentPath = Astro.url.pathname;
---

<div
    class="nav-links flex flex-col items-center space-y-4 md:flex-row md:items-center md:space-y-0 md:space-x-4 py-2"
>
  {links.map((link) => (
      <a
          href={link.href}
          class={`py-1.5 px-3 text-sm rounded-full transition-colors duration-300 ease-in-out ${
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                  ? "bg-black dark:bg-white text-white dark:text-black"
                  : "hover:bg-gray-200 hover:dark:bg-gray-700"
          }`}
      >
        {link.text}
      </a>
  ))}
</div>