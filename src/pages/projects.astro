---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");

// Sort by publishDate descending if available, else by title alphabetically
const sortedProjects = allProjects.sort((a, b) => {
	if (a.data.publishDate && b.data.publishDate) {
		return b.data.publishDate.getTime() - a.data.publishDate.getTime();
	}
	if (a.data.publishDate) return -1;
	if (b.data.publishDate) return 1;
	// fallback to title alphabetical
	return (a.data.title ?? "").localeCompare(b.data.title ?? "");
});

const pageTitle = "Projects";
---

<BaseLayout title={pageTitle}>
    <main class="container mx-auto px-4 py-12">
        <h1 class="text-4xl font-bold mb-8">My Projects</h1>

        {sortedProjects.length === 0 ? (
                <p class="text-center text-gray-600 dark:text-gray-400">
                    No projects found yet. Please check back later.
                </p>
        ) : (
                <section>
                    <h2 class="text-2xl font-semibold mb-6">All Projects</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {sortedProjects.map((project) => {
                            const {
                                title,
                                description,
                                image,
                                technologies,
                                liveUrl,
                                githubUrl,
                                status,
                            } = project.data;

                            return (
                                    <ProjectCard
                                            key={project.id}
                                            title={title}
                                            description={description}
                                            image={image}
                                            tags={technologies}
                                            link={liveUrl}
                                            github={githubUrl}
                                            id={project.id}
                                            status={status}
                        />
                            );
                        })}
                    </div>
                </section>
        )}
    </main>
</BaseLayout>
