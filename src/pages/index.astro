---
import BaseLayout from "@layouts/BaseLayout.astro";
const pageTitle = "Home";

import { getCollection } from "astro:content";
import BlogPost from "@components/BlogPost.astro";
import { sortByDateDesc } from "src/data/utils";

const allPosts = await getCollection("blog");
const sortedPosts = sortByDateDesc(allPosts);
---

<BaseLayout pageTitle={pageTitle}>
  <section class="mb-12">
    <h1 class="text-4xl font-bold mb-4">Hi, I’m Iain Kirkham</h1>
    <p class="text-lg text-gray-200 mb-4">
      I’m a Software Engineer. I write about AWS Cloud, Spring, and Rust.
    </p>
    <a href="/about" class=" hover:underline">
      Read more about me →
    </a>
  </section>
  <section>
    <h2 class="text-2xl font-semibold mb-6">Latest Blog Posts</h2>
    <ul class="space-y-6">
      {
        sortedPosts.map((post: any) => (
            <li>
              <BlogPost
                  url={`/blog/${post.id}/`}
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.pubDate}
              />
            </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
