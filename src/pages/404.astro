---
import "@styles/global.css";
import { SITE } from "src/data/utils";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Error 404 {SITE.title}</title>
  </head>
  <body class="text-center bg-gray-900 text-white max-w-full">
    <div class="place-content-center">
      <h1 class="text-6xl tracking-wide font-bold">Error 404</h1>
      <p class="py-4 pb-6">Sorry, we couldn't find that page! <br/> Press the button below to go back home!</p>
      <a href="/" class="py-2 px-4 bg-sky-500 rounded-lg hover:bg-sky-600 text-white">Home</a>
    </div>
  </body>
</html>
