---
import { getCollection } from "astro:content";
import BlogPost from "@components/BlogPost.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { sortByDateDesc } from "src/data/utils";
const allPosts = await getCollection("blog");
const sortedPosts = sortByDateDesc(allPosts);
const pageTitle = "Blog";
import { VisitorCount } from "@components/VisitorCount.tsx";
---

<BaseLayout pageTitle={pageTitle}>
  <h1>{pageTitle}</h1>
  <p class="py-2">This is where I will post about my journey learning Astro.</p>
  <VisitorCount client:load />
  <ul>
    {
      sortedPosts.map((post: any) => (
          <BlogPost
              url={`/blog/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              date={post.data.pubDate}
          />
      ))
    }
  </ul>
</BaseLayout>